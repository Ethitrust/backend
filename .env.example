# Ethitrust local environment template
# Copy/edit values as needed for your environment.

# Core
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
RABBITMQ_URL=amqp://ethitrust:ethitrust@rabbitmq:5672/
REDIS_URL=redis://redis:6379/0

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-username
SMTP_PASS=replace-with-smtp-password
FROM_EMAIL=noreply@ethitrust.com

# Frontend URL (used in invitation links)
FRONTEND_URL=https://ethitrust.me

# Databases
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Service database URLs (used by components)
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_auth
USER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_user
WALLET_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_wallet
ESCROW_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_escrow
INVOICE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_invoice
PAYMENT_LINK_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_payment_link
PAYOUT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_payout
DISPUTE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_dispute
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_notification
AUDIT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_audit
FEE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_fee
ORGANIZATION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_organization
WEBHOOK_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres/ethitrust_core

# KYC provider
KYC_API_URL=https://api.verifayda.com
KYC_API_KEY=replace-with-kyc-api-key
FAYDA_BASE_URL=https://verifayda.ethitrust.me
FAYDA_API_KEY=replace-with-fayda-api-key
FAYDA_TX_ALIAS_TTL_SECONDS=300

# Optional gRPC host overrides (defaults are defined in code)
AUTH_GRPC=auth-service:50051
USER_GRPC=user-service:50051
WALLET_GRPC=wallet-service:50051
ESCROW_GRPC=escrow-service:50051
PAYMENT_GRPC=payment-provider:50051

# Gateway KYC enforcement policy
KYC_ENFORCEMENT_ENABLED=true
KYC_MIN_LEVEL=1
