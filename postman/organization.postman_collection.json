{
    "info": {
        "name": "Ethitrust Organization Service",
        "description": "Postman collection for Organization routes only (components/organization/app/api.py). Uses gateway by default: {{baseUrl}}.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_postman_id": "7c6ba8eb-9275-4af0-96e6-6ece574f0f73"
    },
    "item": [
        {
            "name": "Organizations",
            "item": [
                {
                    "name": "Create Organization",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 201 || pm.response.code === 200) {",
                                    "  const json = pm.response.json();",
                                    "  if (json?.id) pm.collectionVariables.set('orgId', json.id);",
                                    "  if (json?.public_key) pm.collectionVariables.set('orgPublicKey', json.public_key);",
                                    "  if (json?.secret_key) pm.collectionVariables.set('orgSecretKey', json.secret_key);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"{{orgName}}\",\n  \"slug\": \"{{orgSlug}}\",\n  \"is_test\": true\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/organizations",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations"
                            ]
                        }
                    }
                },
                {
                    "name": "List Organizations",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/organizations",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Organization",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Keys & Webhook",
            "item": [
                {
                    "name": "Rotate Organization Key",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  const json = pm.response.json();",
                                    "  if (json?.public_key) pm.collectionVariables.set('orgPublicKey', json.public_key);",
                                    "  if (json?.secret_key) pm.collectionVariables.set('orgSecretKey', json.secret_key);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/keys/rotate",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "keys",
                                "rotate"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Webhook",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"webhook_url\": \"{{webhookUrl}}\",\n  \"webhook_secret\": \"{{webhookSecret}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/webhook",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "webhook"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Members",
            "item": [
                {
                    "name": "Invite Member",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"user_id\": \"{{targetUserId}}\",\n  \"role\": \"member\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/members",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "members"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Member Role",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role\": \"{{roleName}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/members/{{targetUserId}}/role",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "members",
                                "{{targetUserId}}",
                                "role"
                            ]
                        }
                    }
                },
                {
                    "name": "Remove Member",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/members/{{targetUserId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "members",
                                "{{targetUserId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Check Member Exists (Internal)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/members/{{checkUserId}}/exists",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "members",
                                "{{checkUserId}}",
                                "exists"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Roles",
            "item": [
                {
                    "name": "List Roles",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  const json = pm.response.json();",
                                    "  if (Array.isArray(json) && json.length > 0 && json[0]?.name) {",
                                    "    pm.collectionVariables.set('roleName', json[0].name);",
                                    "  }",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/roles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "roles"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Role Permissions",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"permissions\": [\n    \"members.read\",\n    \"members.write\",\n    \"roles.read\"\n  ]\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/organizations/{{orgId}}/roles/{{roleName}}/permissions",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "organizations",
                                "{{orgId}}",
                                "roles",
                                "{{roleName}}",
                                "permissions"
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000"
        },
        {
            "key": "authToken",
            "value": ""
        },
        {
            "key": "orgName",
            "value": "Acme Labs"
        },
        {
            "key": "orgSlug",
            "value": "acme-labs"
        },
        {
            "key": "orgId",
            "value": "11111111-1111-1111-1111-111111111111"
        },
        {
            "key": "targetUserId",
            "value": "22222222-2222-2222-2222-222222222222"
        },
        {
            "key": "checkUserId",
            "value": "22222222-2222-2222-2222-222222222222"
        },
        {
            "key": "roleName",
            "value": "member"
        },
        {
            "key": "webhookUrl",
            "value": "https://example.com/webhooks/organization"
        },
        {
            "key": "webhookSecret",
            "value": "supersecretvalue123"
        },
        {
            "key": "orgPublicKey",
            "value": ""
        },
        {
            "key": "orgSecretKey",
            "value": ""
        }
    ]
}