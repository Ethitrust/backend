{
    "info": {
        "name": "Ethitrust Payout Service",
        "description": "Postman collection for Payout routes defined in components/payout/app/api.py.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_postman_id": "9ce468fc-6d18-4f6d-9f64-5fdd55c6c8f8"
    },
    "item": [
        {
            "name": "Payout",
            "item": [
                {
                    "name": "Request Payout",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "  const data = pm.response.json();",
                                    "  if (data?.id) pm.collectionVariables.set('payoutId', data.id);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"wallet_id\": \"{{walletId}}\",\n  \"amount\": {{amount}},\n  \"currency\": \"{{currency}}\",\n  \"bank_code\": \"{{bankCode}}\",\n  \"account_number\": \"{{accountNumber}}\",\n  \"account_name\": \"{{accountName}}\",\n  \"provider\": \"{{provider}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/payout/request",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payout",
                                "request"
                            ]
                        }
                    }
                },
                {
                    "name": "Process Bank Transfer (ET)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/payout/bank-transfer/et/{{payoutId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payout",
                                "bank-transfer",
                                "et",
                                "{{payoutId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Payout",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/payout/{{payoutId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payout",
                                "{{payoutId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "List Payouts",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/payout?page={{page}}&limit={{limit}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "payout"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "{{page}}"
                                },
                                {
                                    "key": "limit",
                                    "value": "{{limit}}"
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000"
        },
        {
            "key": "authToken",
            "value": ""
        },
        {
            "key": "walletId",
            "value": "11111111-1111-1111-1111-111111111111"
        },
        {
            "key": "payoutId",
            "value": "11111111-1111-1111-1111-111111111111"
        },
        {
            "key": "amount",
            "value": "1000"
        },
        {
            "key": "currency",
            "value": "ETB"
        },
        {
            "key": "bankCode",
            "value": "CBE"
        },
        {
            "key": "accountNumber",
            "value": "1000000000"
        },
        {
            "key": "accountName",
            "value": "Test User"
        },
        {
            "key": "provider",
            "value": "chapa"
        },
        {
            "key": "page",
            "value": "1"
        },
        {
            "key": "limit",
            "value": "20"
        }
    ]
}