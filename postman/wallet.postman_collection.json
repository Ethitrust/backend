{
    "info": {
        "name": "Ethitrust Wallet Service",
        "description": "Postman collection for Wallet routes defined in components/wallet/app/api.py.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_postman_id": "6f9f40e5-00f8-4dc6-8907-2e099bcf90fc"
    },
    "item": [
        {
            "name": "Wallet",
            "item": [
                {
                    "name": "List Wallets",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  const data = pm.response.json();",
                                    "  if (Array.isArray(data) && data.length > 0) {",
                                    "    if (data[0].id) pm.collectionVariables.set('walletId', data[0].id);",
                                    "    if (data[0].currency) pm.collectionVariables.set('currency', data[0].currency);",
                                    "  }",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/wallet",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "wallet"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Wallet",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/wallet/{{walletId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "wallet",
                                "{{walletId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Wallet Balance",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/wallet/{{walletId}}/balance",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "wallet",
                                "{{walletId}}",
                                "balance"
                            ]
                        }
                    }
                },
                {
                    "name": "Fund Wallet",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 202) {",
                                    "  const data = pm.response.json();",
                                    "  if (data?.transaction_ref) pm.collectionVariables.set('transactionRef', data.transaction_ref);",
                                    "  if (data?.payment_url) pm.collectionVariables.set('paymentUrl', data.payment_url);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"amount\": {{amount}},\n  \"currency\": \"{{currency}}\",\n  \"provider\": \"{{provider}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/wallet/{{walletId}}/fund",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "wallet",
                                "{{walletId}}",
                                "fund"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Wallet Transactions",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/wallet/{{walletId}}/transactions?page={{page}}&limit={{limit}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "wallet",
                                "{{walletId}}",
                                "transactions"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "{{page}}"
                                },
                                {
                                    "key": "limit",
                                    "value": "{{limit}}"
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000"
        },
        {
            "key": "authToken",
            "value": ""
        },
        {
            "key": "walletId",
            "value": "11111111-1111-1111-1111-111111111111"
        },
        {
            "key": "currency",
            "value": "ETB"
        },
        {
            "key": "amount",
            "value": "1000"
        },
        {
            "key": "provider",
            "value": "chapa"
        },
        {
            "key": "page",
            "value": "1"
        },
        {
            "key": "limit",
            "value": "20"
        },
        {
            "key": "transactionRef",
            "value": ""
        },
        {
            "key": "paymentUrl",
            "value": ""
        }
    ]
}