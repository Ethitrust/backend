{
    "info": {
        "name": "Ethitrust Notification Service",
        "description": "Postman collection for the Notification component only (components/notification). Uses gateway by default: {{baseUrl}}.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "_postman_id": "928f7740-68df-4ec6-8ec2-8398f8ed1ec8"
    },
    "item": [
        {
            "name": "Notifications",
            "item": [
                {
                    "name": "List Notifications",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  const json = pm.response.json();",
                                    "  if (Array.isArray(json) && json.length > 0) {",
                                    "    const first = json[0];",
                                    "    const id = first?.id || first?.notification_id || first?.notif_id;",
                                    "    if (id) pm.collectionVariables.set('notifId', id);",
                                    "  }",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/notifications?page={{page}}&limit={{limit}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "notifications"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "{{page}}"
                                },
                                {
                                    "key": "limit",
                                    "value": "{{limit}}"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Create Notification (Internal)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"user_id\": \"{{targetUserId}}\",\n  \"type\": \"system\",\n  \"title\": \"Welcome to Ethitrust\",\n  \"body\": \"Your account setup is complete.\",\n  \"metadata\": {\n    \"source\": \"postman\"\n  }\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/notifications/internal",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "notifications",
                                "internal"
                            ]
                        }
                    }
                },
                {
                    "name": "Mark Notification Read",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/notifications/{{notifId}}/read",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "notifications",
                                "{{notifId}}",
                                "read"
                            ]
                        }
                    }
                },
                {
                    "name": "Mark All Notifications Read",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/notifications/read-all",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "notifications",
                                "read-all"
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000"
        },
        {
            "key": "authToken",
            "value": ""
        },
        {
            "key": "notifId",
            "value": "11111111-1111-1111-1111-111111111111"
        },
        {
            "key": "targetUserId",
            "value": "11111111-1111-1111-1111-111111111111"
        },
        {
            "key": "page",
            "value": "1"
        },
        {
            "key": "limit",
            "value": "20"
        }
    ]
}